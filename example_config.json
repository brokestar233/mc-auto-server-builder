{
  "memory": {
    "xmx": "6G",
    "xms": "4G",
    "max_ram_ratio": 0.7
  },
  "runtime": {
    "max_attempts": 20,
    "start_timeout": 300,
    "keep_running": false,
    "startup_soft_timeout": 45,
    "startup_hard_timeout": 300
  },
  "ai": {
    "enabled": true,
    "provider": "openai_compatible",
    "model": "gpt-5.4-mini",
    "base_url": "https://api.openai.com",
    "api_key": "<YOUR_API_KEY>",
    "temperature": 0.2,
    "max_tokens": 1024,
    "timeout_sec": 300,
    "debug": false
  },
  "logging": {
    "level": "INFO",
    "color_policy": "auto"
  },
  "download": {
    "enable_parallel_download": true,
    "max_workers": 32,
    "connect_timeout": 15,
    "read_timeout": 120
  },
  "server_port": 25565,
  "github_api_key": "",
  "oracle_download_cookies": "",
  "curseforge_api_key": "",
  "modrinth_api_token": "",
  "modrinth_user_agent": "brokestar233/mc-auto-server-builder",
  "graalvm_external_packages": [],
  "extra_jvm_flags": [],
  "user_blacklist_regex": []
}
